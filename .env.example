# ============================================================
# ECOMMERCE PLATFORM - ENV EXAMPLE
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# ----- ENTORNO -----
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
WORKER_URL=http://localhost:4001

# ----- BASE DE DATOS -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=ecommerce_dev
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# ----- REDIS -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_in_prod
REDIS_URL="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# ----- MEILISEARCH -----
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=changeme_in_prod

# ----- JWT -----
JWT_SECRET=super_secret_jwt_key_min_32_chars_change_in_prod
JWT_REFRESH_SECRET=super_secret_refresh_key_min_32_chars_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- ADMIN AUTH -----
ADMIN_JWT_SECRET=super_secret_admin_jwt_key_min_32_chars_change_in_prod
ADMIN_JWT_EXPIRES_IN=8h

# ----- MASTER KEY (cifrado credenciales pasarelas) -----
MASTER_ENCRYPTION_KEY=32_char_hex_key_change_in_prod_NOW

# ----- STRIPE -----
# (Las credenciales reales se configuran desde admin panel)
STRIPE_WEBHOOK_SECRET_SANDBOX=whsec_sandbox_example
STRIPE_WEBHOOK_SECRET_LIVE=whsec_live_example

# ----- MERCADO PAGO -----
MP_WEBHOOK_SECRET=mp_webhook_secret_example

# ----- PAYPAL -----
PAYPAL_WEBHOOK_ID_SANDBOX=paypal_webhook_sandbox_id
PAYPAL_WEBHOOK_ID_LIVE=paypal_webhook_live_id

# ----- STORAGE (MinIO dev / S3-compatible) -----
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ecommerce
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_URL=http://localhost:9000/ecommerce

# ----- EMAIL (Resend) -----
RESEND_API_KEY=re_example_key
EMAIL_FROM=noreply@tutienda.com
EMAIL_FROM_NAME=Mi Tienda

# ----- SENTRY -----
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=development

# ----- OBSERVABILIDAD -----
LOG_LEVEL=debug
LOG_FORMAT=pretty  # pretty | json

# ----- PWA / PUSH NOTIFICATIONS -----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tutienda.com

# ----- TRACKING -----
# (Configurado desde admin panel, estas son solo para fallback)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
META_PIXEL_ID=
META_ACCESS_TOKEN=

# ----- BACKUPS -----
BACKUP_ENCRYPTION_KEY=32_char_hex_key_for_backups_change_NOW
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=ecommerce-backups
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# ----- RATE LIMITING -----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ----- CORS -----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----- NEXT.JS PUBLIC -----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
